<view class="page">
  <view class="hero">
    <view class="title">{{text.title}}</view>
    <view class="desc">{{text.desc}}</view>
  </view>

  <view class="section">
    <view class="sectionTitle">可同行时间</view>
    <view class="optionList">
      <view
        class="optionChip {{form.availability === item.value ? 'active' : ''}}"
        wx:for="{{optionGroups.availability}}"
        wx:key="value"
        data-field="availability"
        data-value="{{item.value}}"
        bindtap="selectOption"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">同行类型</view>
    <view class="optionList">
      <view
        class="optionChip {{form.buddyType === item.value ? 'active' : ''}}"
        wx:for="{{optionGroups.buddyType}}"
        wx:key="value"
        data-field="buddyType"
        data-value="{{item.value}}"
        bindtap="selectOption"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">是否接受拼车</view>
    <view class="optionList">
      <view
        class="optionChip {{form.acceptCarpool === item.value ? 'active' : ''}}"
        wx:for="{{optionGroups.acceptCarpool}}"
        wx:key="value"
        data-field="acceptCarpool"
        data-value="{{item.value}}"
        bindtap="selectOption"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">偏好几人同行</view>
    <view class="optionList">
      <view
        class="optionChip {{form.groupPreference === item.value ? 'active' : ''}}"
        wx:for="{{optionGroups.groupPreference}}"
        wx:key="value"
        data-field="groupPreference"
        data-value="{{item.value}}"
        bindtap="selectOption"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="saveBtn" bindtap="saveIntent">{{loading ? '保存中' : text.save}}</view>
</view>
