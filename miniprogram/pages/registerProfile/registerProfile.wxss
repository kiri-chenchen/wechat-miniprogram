.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f3efdf 0%, #edf6e8 100%);
}

.content {
  flex: 1;
  padding: 26rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.avatarSection {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0 24rpx;
}

.avatar {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: #edf5ea;
  box-shadow: 0 10rpx 22rpx rgba(59, 84, 63, 0.08);
}

.avatarHintText {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5d705d;
  line-height: 1.5;
  text-align: center;
}

.section {
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 10rpx 24rpx rgba(59, 84, 63, 0.05);
}

.inlineField {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.inlineField + .inlineField {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(86, 112, 85, 0.08);
}

.inlineFieldGender {
  align-items: center;
}

.inlineLabel {
  width: 72rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #50604f;
}

.inlineInputWrap {
  position: relative;
  flex: 1;
  min-width: 0;
}

.inlineInput {
  width: 100%;
  height: 78rpx;
  padding: 0 90rpx 0 18rpx;
  border-radius: 18rpx;
  background: rgba(247, 248, 243, 0.9);
  border: 1rpx solid #dfe7d8;
  color: #263029;
  font-size: 28rpx;
  box-sizing: border-box;
}

.inlineCount {
  position: absolute;
  top: 50%;
  right: 18rpx;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #879283;
}

.picker {
  flex: 1;
  min-width: 0;
}

.pickerView {
  box-sizing: border-box;
  width: 100%;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: rgba(247, 248, 243, 0.9);
  border: 1rpx solid #dfe7d8;
  color: #263029;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.inlinePickerView {
  min-height: 78rpx;
}

.placeholder {
  color: #9aa593;
}

.sectionLabel {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: #50604f;
}

.noMargin {
  margin-bottom: 0;
}

.birthHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.birthDateRow {
  display: flex;
  align-items: center;
}

.pickerSmall {
  min-width: 0;
}

.separator {
  padding: 0 10rpx;
  color: #97a292;
}

.arrow {
  color: #8a9887;
}

.birthUnknown {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #879283;
}

.footer {
  padding: 20rpx 32rpx 36rpx;
  background: rgba(237, 246, 232, 0.92);
}

.btnSave {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: #57984a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
