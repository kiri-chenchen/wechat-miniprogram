<view class="page">
  <scroll-view scroll-y class="content">
    <view class="avatarSection" bindtap="onSelectAvatar">
      <image src="{{avatarPreview || '/images/avatar.png'}}" mode="aspectFill" class="avatar" binderror="onAvatarError"></image>
      <view class="avatarHintText">{{text.avatarHint}}</view>
    </view>

    <view class="section">
      <view class="inlineField">
        <view class="inlineLabel">{{text.nickname}}</view>
        <view class="inlineInputWrap">
          <input
            class="inlineInput"
            type="text"
            placeholder="{{text.nicknamePlaceholder}}"
            placeholder-class="placeholder"
            value="{{nickname}}"
            bindinput="onNicknameInput"
            maxlength="10"
          />
          <view class="inlineCount">{{nickname.length}}/10</view>
        </view>
      </view>

      <view class="inlineField inlineFieldGender">
        <view class="inlineLabel">{{text.gender}}</view>
        <picker mode="selector" range="{{genders}}" bindchange="pickerGender" class="picker">
          <view class="pickerView inlinePickerView">
            <text>{{gender}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
    </view>

    <view class="section">
      <view class="birthHeader">
        <view class="sectionLabel noMargin">{{text.birth}}</view>
        <switch checked="{{birthEnabled}}" color="#57984a" bindchange="toggleBirthEnabled" />
      </view>

      <view class="birthDateRow" wx:if="{{birthEnabled}}">
        <picker mode="selector" range="{{years}}" value="{{selectedYearIndex}}" bindchange="pickerYear" class="picker">
          <view class="pickerView pickerSmall">
            <text>{{birth.year}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
        <text class="separator">-</text>
        <picker mode="selector" range="{{months}}" value="{{selectedMonthIndex}}" bindchange="pickerMonth" class="picker">
          <view class="pickerView pickerSmall">
            <text>{{birth.month}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
        <text class="separator">-</text>
        <picker mode="selector" range="{{days}}" value="{{selectedDayIndex}}" bindchange="pickerDay" class="picker">
          <view class="pickerView pickerSmall">
            <text>{{birth.day}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>

      <view class="birthUnknown" wx:else>{{text.birthUnknown}}</view>
    </view>
  </scroll-view>

  <view class="footer">
    <button class="btnSave" bindtap="onSave" loading="{{loading}}" disabled="{{loading}}">
      {{mode === 'edit' ? text.save : text.nextStep}}
    </button>
  </view>
</view>
